        "id": "a8e63b5e120b0412",
        "type": "function",
        "z": "751db66ae21c7d98",
        "name": "SECLOG",
        "func": "// Security-focused audit log for control actions (Node-RED -> tank-sim)\n// Logs only commands (not every /state poll)\n\n// Try to capture the command payload in a consistent way\nconst payload = msg.payload || {};\nconst cmdType =\n  payload.type || payload.command || payload.action || msg.topic || \"command\";\n\n// Minimal but useful audit event\nconst evt = {\n  ts: new Date().toISOString(),\n  component: \"node-red\",\n  event_type: \"control_action\",\n  cmd: cmdType,\n  payload: payload,\n  flow: \"TankSim\",\n  src_node: \"SECLOG: command audit\"\n};\n\nevt.marker = \"SECLOG_MARKER_123\";\n\n// Write JSON to Node-RED logs (stdout)\nnode.warn(JSON.stringify(evt));\n\nreturn msg;\n",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
