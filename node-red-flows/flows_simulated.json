    {
        "id": "64b1ea7da227b4cd",
        "type": "function",
        "z": "751db66ae21c7d98",
        "name": "Auto pump controller",
        "func": "// Auto pump controller, runs on every /state poll\nlet s = msg.payload;\n\n// target comes from TankSim state\nlet TARGET = s.target_cm;\nif (TARGET === undefined || TARGET === null) TARGET = 50;\n\nconst FAR_BAND = 10;    // cm below target where we start ramping\nconst BASE_HOLD = 25;   // minimum power near target to fight leak\n\n\nif (!s.pump_on) {\n    // Pump is off, do not send anything\n    return null;\n}\n\nlet level = s.level_cm;\nlet error = TARGET - level;   // cm below target\n\nlet power;\n\n// At or above target: cut power completely\nif (error <= 0) {\n    power = 0;\n\n} else if (error >= FAR_BAND) {\n    // Far from target: full power, we want to get there quickly\n    power = 100;\n\n} else {\n    // Close to target: linear ramp between BASE_HOLD and 100\n    // error in (0..FAR_BAND) -> x in (0..1)\n    let x = error / FAR_BAND;\n\n    // Linear ramp, not squared, so it does not drop too early\n    power = BASE_HOLD + (100 - BASE_HOLD) * x;\n}\n\n// Integers only\npower = Math.round(power);\nif (power < 0) power = 0;\nif (power > 100) power = 100;\n\n// Build command for backend\nmsg.headers = { \"Content-Type\": \"application/json\" };\nmsg.payload = JSON.stringify({\n    pump_on: true,\n    pump_power: power\n});\n\nreturn msg;\n",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 660,
        "y": 500,
        "wires": [
            [
                "a8e63b5e120b0412"
            ]
        ]
    },
