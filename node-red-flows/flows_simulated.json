    {
        "id": "d1d4eef678a9836c",
        "type": "function",
        "z": "751db66ae21c7d98",
        "name": "Pump power command",
        "func": "let val = Number(msg.payload);\nif (isNaN(val)) val = 0;\nif (val < 0) val = 0;\nif (val > 100) val = 100;\n\nmsg.headers = { \"Content-Type\": \"application/json\" };\nmsg.payload = JSON.stringify({ pump_power: val });\nreturn msg;\n",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
